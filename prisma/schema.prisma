generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────────
model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  name        String
  nameEN      String?
  role        UserRole  @default(HR)
  status      UserStatus @default(ACTIVE)
  companies   UserCompany[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum UserRole  { ADMIN HR VIEW }
enum UserStatus { ACTIVE INACTIVE }

model UserCompany {
  id        Int     @id @default(autoincrement())
  userId    Int
  companyId Int
  user      User    @relation(fields:[userId], references:[id], onDelete:Cascade)
  company   Company @relation(fields:[companyId], references:[id], onDelete:Cascade)
  @@unique([userId, companyId])
}

// ─── Company ──────────────────────────────────────────
model Company {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(10)
  name        String
  nameTH      String
  taxId       String?
  address     String?
  phone       String?
  email       String?
  website     String?
  color       String    @default("#e6faf9")
  textColor   String    @default("#007d75")
  payrollCycle String   @default("สิ้นเดือน")
  status      CompanyStatus @default(ACTIVE)
  users       UserCompany[]
  departments Department[]
  positions   Position[]
  employees   Employee[]
  holidays    Holiday[]
  leaveTypes  LeaveType[]
  shifts      Shift[]
  payrollRuns PayrollRun[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum CompanyStatus { ACTIVE INACTIVE }

model Department {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  company   Company  @relation(fields:[companyId], references:[id], onDelete:Cascade)
  employees Employee[]
  @@unique([companyId, name])
}

model Position {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  company   Company  @relation(fields:[companyId], references:[id], onDelete:Cascade)
  employees Employee[]
  @@unique([companyId, name])
}

// ─── Holiday & Leave ──────────────────────────────────
model Holiday {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  date      DateTime @db.Date
  year      Int
  isNational Boolean @default(false)
  company   Company  @relation(fields:[companyId], references:[id], onDelete:Cascade)
}

model LeaveType {
  id            Int      @id @default(autoincrement())
  companyId     Int
  name          String
  icon          String   @default("Calendar")
  color         String   @default("#e6faf9")
  maxDaysPerYear Int?
  isPaid        Boolean  @default(true)
  requireApproval Boolean @default(true)
  isAccumulated Boolean  @default(false)
  noLimit       Boolean  @default(false)
  company       Company  @relation(fields:[companyId], references:[id], onDelete:Cascade)
}

// ─── Employee ─────────────────────────────────────────
model Employee {
  id             Int          @id @default(autoincrement())
  empCode        String       @unique
  companyId      Int
  departmentId   Int?
  positionId     Int?
  shiftId        Int?
  managerId      Int?
  firstName      String
  lastName       String
  firstNameEN    String?
  lastNameEN     String?
  nickname       String?
  gender         String?
  birthDate      DateTime?    @db.Date
  nationalId     String?
  phone          String
  email          String       @unique
  address        String?
  contractType   ContractType @default(MONTHLY)
  hireDate       DateTime     @db.Date
  status         EmpStatus    @default(PROBATION)
  baseSalary     Decimal      @db.Decimal(12,2)
  bank           String?
  bankAccount    String?
  profileColor   String       @default("#e6faf9")
  profileTextColor String     @default("#007d75")
  canApproveLeave Boolean     @default(false)

  company        Company      @relation(fields:[companyId], references:[id])
  department     Department?  @relation(fields:[departmentId], references:[id])
  position       Position?    @relation(fields:[positionId], references:[id])
  shift          Shift?       @relation(fields:[shiftId], references:[id])
  manager        Employee?    @relation("ManagerSubordinate", fields:[managerId], references:[id])
  subordinates   Employee[]   @relation("ManagerSubordinate")
  benefits       EmployeeBenefit[]
  history        EmployeeHistory[]
  payrollItems   PayrollItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum ContractType { MONTHLY DAILY PARTTIME INTERN CONSULTANT }
enum EmpStatus    { PROBATION ACTIVE RESIGNED TERMINATED }

model EmployeeBenefit {
  id         Int      @id @default(autoincrement())
  employeeId Int
  name       String
  amount     Decimal  @db.Decimal(10,2)
  employee   Employee @relation(fields:[employeeId], references:[id], onDelete:Cascade)
}

model EmployeeHistory {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       DateTime @db.Date
  type       String
  title      String
  description String?
  employee   Employee @relation(fields:[employeeId], references:[id], onDelete:Cascade)
}

// ─── Shift ────────────────────────────────────────────
model Shift {
  id          Int       @id @default(autoincrement())
  companyId   Int
  name        String
  code        String
  startTime   String    @db.VarChar(5)
  endTime     String    @db.VarChar(5)
  breakMins   Int       @default(60)
  hoursPerDay Decimal   @db.Decimal(4,1)
  workDays    Int[]
  shiftType   ShiftType @default(STANDARD)
  color       String    @default("#e6faf9")
  textColor   String    @default("#007d75")
  company     Company   @relation(fields:[companyId], references:[id], onDelete:Cascade)
  employees   Employee[]
  @@unique([companyId, code])
}

enum ShiftType { STANDARD SHIFT ROTATING FLEXIBLE }

// ─── Payroll ──────────────────────────────────────────
model PayrollRun {
  id          Int           @id @default(autoincrement())
  companyId   Int
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  totalGross  Decimal       @db.Decimal(14,2) @default(0)
  totalBenefits Decimal     @db.Decimal(14,2) @default(0)
  totalBonus  Decimal       @db.Decimal(14,2) @default(0)
  totalTax    Decimal       @db.Decimal(14,2) @default(0)
  totalSso    Decimal       @db.Decimal(14,2) @default(0)
  totalNet    Decimal       @db.Decimal(14,2) @default(0)
  approvedAt  DateTime?
  paidAt      DateTime?
  company     Company       @relation(fields:[companyId], references:[id])
  items       PayrollItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@unique([companyId, month, year])
}

enum PayrollStatus { DRAFT REVIEW APPROVED PAID }

model PayrollItem {
  id           Int        @id @default(autoincrement())
  payrollRunId Int
  employeeId   Int
  baseAmount   Decimal    @db.Decimal(12,2)
  benefits     Decimal    @db.Decimal(10,2) @default(0)
  bonus        Decimal    @db.Decimal(10,2) @default(0)
  tax          Decimal    @db.Decimal(10,2) @default(0)
  sso          Decimal    @db.Decimal(10,2) @default(0)
  otherDeduct  Decimal    @db.Decimal(10,2) @default(0)
  netAmount    Decimal    @db.Decimal(12,2)
  hoursWorked  Decimal?   @db.Decimal(6,2)
  payrollRun   PayrollRun @relation(fields:[payrollRunId], references:[id], onDelete:Cascade)
  employee     Employee   @relation(fields:[employeeId], references:[id])
  @@unique([payrollRunId, employeeId])
}
