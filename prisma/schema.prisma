generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  name      String
  role      String        @default("HR")
  status    String        @default("ACTIVE")
  companies UserCompany[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model UserCompany {
  id        Int     @id @default(autoincrement())
  userId    Int
  companyId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([userId, companyId])
}

model Company {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  name         String
  nameTH       String
  color        String       @default("#e6faf9")
  textColor    String       @default("#007d75")
  payrollCycle String       @default("monthly")
  status       String       @default("ACTIVE")
  users        UserCompany[]
  departments  Department[]
  positions    Position[]
  employees    Employee[]
  shifts       Shift[]
  payrollRuns  PayrollRun[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Department {
  id        Int        @id @default(autoincrement())
  companyId Int
  name      String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  @@unique([companyId, name])
}

model Position {
  id        Int        @id @default(autoincrement())
  companyId Int
  name      String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  @@unique([companyId, name])
}

model Employee {
  id              Int               @id @default(autoincrement())
  empCode         String            @unique
  companyId       Int
  departmentId    Int?
  positionId      Int?
  shiftId         Int?
  managerId       Int?
  firstName       String
  lastName        String
  phone           String
  email           String            @unique
  contractType    String            @default("MONTHLY")
  hireDate        DateTime          @db.Date
  status          String            @default("PROBATION")
  baseSalary      Decimal           @db.Decimal(12, 2)
  bank            String?
  bankAccount     String?
  canApproveLeave Boolean           @default(false)
  company         Company           @relation(fields: [companyId], references: [id])
  department      Department?       @relation(fields: [departmentId], references: [id])
  position        Position?         @relation(fields: [positionId], references: [id])
  shift           Shift?            @relation(fields: [shiftId], references: [id])
  manager         Employee?         @relation("Mgr", fields: [managerId], references: [id])
  subordinates    Employee[]        @relation("Mgr")
  benefits        EmployeeBenefit[]
  payrollItems    PayrollItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model EmployeeBenefit {
  id         Int      @id @default(autoincrement())
  employeeId Int
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Shift {
  id          Int        @id @default(autoincrement())
  companyId   Int
  name        String
  code        String
  startTime   String
  endTime     String
  breakMins   Int        @default(60)
  hoursPerDay Decimal    @db.Decimal(4, 1)
  workDays    Int[]
  shiftType   String     @default("STANDARD")
  color       String     @default("#e6faf9")
  textColor   String     @default("#007d75")
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]
  @@unique([companyId, code])
}

model PayrollRun {
  id            Int          @id @default(autoincrement())
  companyId     Int
  month         Int
  year          Int
  status        String       @default("DRAFT")
  totalGross    Decimal      @default(0) @db.Decimal(14, 2)
  totalBenefits Decimal      @default(0) @db.Decimal(14, 2)
  totalBonus    Decimal      @default(0) @db.Decimal(14, 2)
  totalTax      Decimal      @default(0) @db.Decimal(14, 2)
  totalSso      Decimal      @default(0) @db.Decimal(14, 2)
  totalNet      Decimal      @default(0) @db.Decimal(14, 2)
  approvedAt    DateTime?
  paidAt        DateTime?
  company       Company      @relation(fields: [companyId], references: [id])
  items         PayrollItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@unique([companyId, month, year])
}

model PayrollItem {
  id           Int        @id @default(autoincrement())
  payrollRunId Int
  employeeId   Int
  baseAmount   Decimal    @db.Decimal(12, 2)
  benefits     Decimal    @default(0) @db.Decimal(10, 2)
  bonus        Decimal    @default(0) @db.Decimal(10, 2)
  tax          Decimal    @default(0) @db.Decimal(10, 2)
  sso          Decimal    @default(0) @db.Decimal(10, 2)
  otherDeduct  Decimal    @default(0) @db.Decimal(10, 2)
  netAmount    Decimal    @db.Decimal(12, 2)
  hoursWorked  Decimal?   @db.Decimal(6, 2)
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee     Employee   @relation(fields: [employeeId], references: [id])
  @@unique([payrollRunId, employeeId])
}
